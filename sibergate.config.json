{
  "providers": [
    {
      "id": "openai",
      "name": "OpenAI",
      "baseUrl": "https://api.openai.com/v1",
      "authScheme": "bearer",
      "apiKeyEnv": "OPENAI_API_KEY"
    },
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "baseUrl": "https://api.deepseek.com/v1",
      "authScheme": "bearer",
      "apiKeyEnv": "DEEPSEEK_API_KEY"
    },
    {
      "id": "groq",
      "name": "Groq",
      "baseUrl": "https://api.groq.com/openai/v1",
      "authScheme": "bearer",
      "apiKeyEnv": "GROQ_API_KEY"
    }
  ],
  "models": [
    {
      "id": "gpt-4o-mini",
      "provider": "openai",
      "displayName": "GPT-4o mini",
      "modalities": ["text-to-text", "vision"],
      "contextWindow": 128000,
      "maxOutput": 16384,
      "inputPricePer1m": 0.15,
      "outputPricePer1m": 0.6,
      "capabilities": { "supports_streaming": true, "supports_tools": true, "supports_json": true }
    },
    {
      "id": "deepseek-chat",
      "provider": "deepseek",
      "displayName": "DeepSeek Chat",
      "modalities": ["text-to-text"],
      "contextWindow": 64000,
      "inputPricePer1m": 0.14,
      "outputPricePer1m": 0.28,
      "capabilities": { "supports_streaming": true, "supports_tools": true, "supports_json": true }
    },
    {
      "id": "llama-3.3-70b-versatile",
      "provider": "groq",
      "displayName": "Llama 3.3 70B",
      "modalities": ["text-to-text"],
      "contextWindow": 128000,
      "inputPricePer1m": 0.59,
      "outputPricePer1m": 0.79,
      "capabilities": { "supports_streaming": true, "supports_tools": true }
    }
  ],
  "routes": [
    {
      "id": "smart",
      "name": "Smart (auto-fastest)",
      "strategy": "fastest",
      "comment": "Auto-pick whichever provider responds fastest right now",
      "targets": [
        { "provider": "openai", "model": "gpt-4o-mini", "priority": 0 },
        { "provider": "deepseek", "model": "deepseek-chat", "priority": 1 },
        { "provider": "groq", "model": "llama-3.3-70b-versatile", "priority": 2 }
      ]
    },
    {
      "id": "chat",
      "name": "Chat (fallback)",
      "strategy": "fallback",
      "comment": "Try OpenAI first; on failure fall over to DeepSeek, then Groq",
      "targets": [
        { "provider": "openai", "model": "gpt-4o-mini", "priority": 0 },
        { "provider": "deepseek", "model": "deepseek-chat", "priority": 1 },
        { "provider": "groq", "model": "llama-3.3-70b-versatile", "priority": 2 }
      ]
    },
    {
      "id": "balanced",
      "name": "Balanced (weighted)",
      "strategy": "weighted",
      "comment": "Spread load 50/30/20 across providers to dodge rate limits",
      "targets": [
        { "provider": "openai", "model": "gpt-4o-mini", "weight": 5 },
        { "provider": "deepseek", "model": "deepseek-chat", "weight": 3 },
        { "provider": "groq", "model": "llama-3.3-70b-versatile", "weight": 2 }
      ]
    }
  ]
}
