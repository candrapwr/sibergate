# ─────────────────────────────────────────────────────────────
# SiberGate Admin Panel — Next.js server-side env
# Copy to `.env.local`. These are NEVER exposed to the browser — the
# /api/admin/* proxy route reads them server-side only.
# ─────────────────────────────────────────────────────────────

# Gateway admin key (must match SIBERGATE_ADMIN_KEY on the gateway).
SIBERGATE_ADMIN_KEY=sg_admin_change_me_to_a_long_random_string

# Gateway base URL (the proxy forwards /api/admin/* → here).
SIBERGATE_GATEWAY_URL=http://localhost:8787

# Session signing secret (must match the gateway's SIBERGATE_SESSION_SECRET).
# Used to verify login cookies locally in the proxy route.
SIBERGATE_SESSION_SECRET=change_me_to_a_random_string_min_16_chars

# Optional: port the admin dashboard listens on (default: 3000).
# Used by `next dev`/`next start` via the -p flag.
# SIBERGATE_ADMIN_PORT=3000

# PUBLIC gateway URL shown in the dashboard's sample-code snippets.
# The NEXT_PUBLIC_ prefix exposes it to the browser. In production, set this to
# the URL your clients use to reach the gateway (e.g. https://gate.idsiber.com),
# so generated cURL/SDK samples point there instead of the admin's own origin.
# Leave unset in local dev — samples then fall back to http://<this host>:8787.
# NEXT_PUBLIC_SIBERGATE_PUBLIC_URL=https://gate.idsiber.com

# A CLIENT key (sg_live_*) used by the playground, media lab, and route tester
# so they can call /v1/* WITHOUT asking the operator to paste a key each time.
# IMPORTANT: this must be a real client key created on the API Keys page — the
# gateway /v1/* surface authenticates client keys, NOT the admin key. Pick a
# dedicated key for this purpose (e.g. name it "playground"). If unset, those
# UIs will ask the operator to supply their own key (old behavior).
# SIBERGATE_PLAYGROUND_KEY=sg_live_xxxxxxxxxxxxxxxx
