# ─────────────────────────────────────────────────────────────
# SiberGate Admin Panel — Next.js server-side env
# Copy to `.env.local`. These are NEVER exposed to the browser — the
# /api/admin/* proxy route reads them server-side only.
# ─────────────────────────────────────────────────────────────

# Gateway admin key (must match SIBERGATE_ADMIN_KEY on the gateway).
SIBERGATE_ADMIN_KEY=sg_admin_change_me_to_a_long_random_string

# Gateway base URL (the proxy forwards /api/admin/* → here).
SIBERGATE_GATEWAY_URL=http://localhost:8787

# Session signing secret (must match the gateway's SIBERGATE_SESSION_SECRET).
# Used to verify login cookies locally in the proxy route.
SIBERGATE_SESSION_SECRET=change_me_to_a_random_string_min_16_chars
