# ─────────────────────────────────────────────────────────────
# SiberGate environment
# Copy to `.env` and fill in your provider keys.
#
# Provider keys are NOT seeded here anymore — import the catalog from the
# admin UI (Settings → Import catalog), then set each provider's key there.
# This file only holds gateway/auth config.
# ─────────────────────────────────────────────────────────────

# Server
SIBERGATE_PORT=8787
SIBERGATE_HOST=0.0.0.0

# Admin API key for /admin/* endpoints. If unset, one is auto-generated and
# printed once on boot. Pin it here for stability across restarts.
SIBERGATE_ADMIN_KEY=sg_admin_change_me_to_a_long_random_string

# Admin panel login (auto-seeds the first user). Required for UI access.
SIBERGATE_ADMIN_EMAIL=admin@sibergate.local
SIBERGATE_ADMIN_PASSWORD=change_me_to_a_strong_password

# Secret used to sign login session cookies (>= 16 chars). Rotate to revoke all sessions.
# Must match the admin panel's SIBERGATE_SESSION_SECRET.
SIBERGATE_SESSION_SECRET=change_me_to_a_random_string_min_16_chars

# Optional: SQLite DB path (default: ./sibergate.db)
# SIBERGATE_DB=./sibergate.db

# Optional: pin the encryption master key (default: auto in .sibergate/master-key)
# SIBERGATE_MASTER_KEY=<64 hex chars>
