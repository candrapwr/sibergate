# ─────────────────────────────────────────────────────────────
# SiberGate environment
# Copy to `.env` and fill in your provider keys.
#
# The master encryption key is auto-generated and stored in
# .sibergate/master-key (gitignored). To pin it (e.g. across deploys),
# set SIBERGATE_MASTER_KEY=<64 hex chars> here instead.
# ─────────────────────────────────────────────────────────────

# Provider API keys — referenced by sibergate.config.json "apiKeyEnv" and
# encrypted into SQLite on `npm run seed`. Only fill what you use.
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Server
SIBERGATE_PORT=8787
SIBERGATE_HOST=0.0.0.0

# Admin API key for /admin/* endpoints. If unset, one is auto-generated and
# printed once on boot. Pin it here for stability across restarts.
SIBERGATE_ADMIN_KEY=sg_admin_change_me_to_a_long_random_string

# Optional: config seed file (default: ./sibergate.config.json)
# SIBERGATE_CONFIG=./sibergate.config.json

# Optional: SQLite DB path (default: ./sibergate.db)
# SIBERGATE_DB=./sibergate.db

# Optional: pin the encryption master key (default: auto in .sibergate/master-key)
# SIBERGATE_MASTER_KEY=<64 hex chars>
